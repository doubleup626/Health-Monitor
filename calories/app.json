{
  "configVersion": "v3",
  "app": {
    "appId": 26595,
    "appName": "Health Monitor",
    "appType": "app",
    "version": {
      "code": 1,
      "name": "1.0.0"
    },
    "icon": "icon.png",
    "vender": "zepp",
    "description": "Health and environmental data collection application"
  },
  "permissions": [
    "data:os.device.info",
    "device:os.local_storage",
    "data:user.hd.heart_rate",
    "data:user.hd.spo2",
    "data:user.hd.stress",
    "data:user.hd.body_temp",
    "data:user.hd.step",
    "data:user.hd.calorie",
    "data:user.hd.distance",
    "data:user.hd.sleep",
    "device:os.barometer",
    "device:os.bg_service"
  ],
  "runtime": {
    "apiVersion": {
      "compatible": "4.0",
      "target": "4.0",
      "minVersion": "4.0"
    }
  },
  "targets": {
    "gt": {
      "module": {
        "page": {
          "pages": [
            "page/gt/index"
          ]
        },
        "app-service": {
          "services": [
            "app-service/data-collector"
          ]
        },
        "app-side": {
          "path": "app-side/index"
        }
      },
      "platforms": [
        {
          "st": "r",
          "dw": 480
        },
        {
          "st": "s",
          "dw": 390
        }
      ]
    }
  },
  "i18n": {
    "en-US": {
      "appName": "Health Monitor"
    },
    "zh-CN": {
      "appName": "健康监测"
    }
  },
  "defaultLanguage": "zh-CN"
}
